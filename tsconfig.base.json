{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".", // 项目的根目录
    // ts 7.0 、ts-go 不支持 baseUrl, 所以使用 ignoreDeprecations 来忽略这个选项的弃用警告, 未来如果 ts 7.0 正式发布并且移除了 baseUrl, 可以直接删除这个选项和相关的路径映射配置
    // tsc 使用 --ignoreDeprecations 忽略
    // "ignoreDeprecations": "6.0",

    "outDir": "dist", //  tsc 编译产物输出目录
    "target": "ESNext", // 编译目标 js 的版本
    "module": "ESNext", // 指定模块代码生成
    "moduleResolution": "bundler", // 模块解析策略
    "allowJs": true, // 允许编译 JS 文件
    "resolveJsonModule": true, // 允许引入 .json 模块
    "esModuleInterop": true, // 发出额外的 JavaScript 来简化对导入 CommonJS 模块的支持（import * as React from 'react' 这种写法）
    "allowSyntheticDefaultImports": true, // 允许从没有设置默认导出的模块中默认导入, 与 esModuleInterop: true 配合允许从 commonjs 的依赖中直接按 import XX from 'xxx' 的方式导出 default 模块。
    "allowImportingTsExtensions": true, // 允许导入带有 .ts 扩展名的文件
    "removeComments": false, // 保留注释
    "preserveConstEnums": true, // 保留 const 和 enum 声明
    "forceConsistentCasingInFileNames": true, // 用于强制检查文件路径的大小写一致性, 防止 Mac 和 Windows 之间大小写不一致导致的问题
    "useDefineForClassFields": true, // 使用 defineProperty 来定义类字段, 开启需要 es2022 的支持，关闭可以兼容旧浏览器
    "moduleDetection": "force", // 可选值有："auto"、"legacy"、"force", force 强制 TypeScript 把所有 .ts/.tsx/.mts/.cts 文件当成“模块”（module），而不管它们有没有 import 或 export 语句, 默认行为：只有文件里出现 import/export 时，TypeScript 才会把它当“模块”；否则把它当“脚本”（script），脚本里的代码会被放进全局作用域

    // "lib": [], // 引入 ES 的功能库
    // "types": [], // 默认引入的模块类型声明

    "composite": false, // 这通常是 IDE 和工具链配置的用法——告诉 VSCode / tsc 整个项目的入口是 tsconfig.app.json，根 tsconfig 作为聚合器而不参与实际编译。如果使用 references 引用了多个项目, 修改一个项目其他项目不会重新编译

    "declaration": true, // 生成声明文件
    "declarationMap": true, // 为生成的 .d.ts 声明文件创建对应的 Source Map 文件（.d.ts.map)，但是会被 inlineSources 覆盖, 允许开发者在 IDE 中点击跳转到原始 TypeScript 源码，而不是只能看到编译后的声明文件, 对于发布 npm 包的库作者特别有用，用户可以通过 "Go to Definition" 直接看到你的源代码实现
    "inlineSources": true, // 将原始 TypeScript 源码内容直接嵌入到 Source Map 文件中的 sourcesContent 字段。
    "inlineSourceMap": false, //  把整个 Source Map 嵌入到 .js 文件末尾（base64 编码）
    "allowArbitraryExtensions": true, // 允许导入任意扩展名的文件, 编译器会以 {filename}.d.{ext}.ts 的形式在该路径所在目录中查找相应的声明文件

    "incremental": false, // 是否启用增量编译，大型项目开启可能会因 .tsbuildinfo 导致编译失败
    "sourceMap": true, // 生成 sourceMap 文件

    "emitDeclarationOnly": true, // 只生成声明文件
    "skipLibCheck": true, // 检查类型时是否跳过类型声明文件，可以提升编译速度
    // 使用 import type 和 export type 必须明确用于类型导入，
    // false 时，可以省略 type 关键字并且
    // true 时 TypeScript 会自动将只用于类型的导入转换为 import type(会自动导入 type 关键字, 但是可能会错误, 最好还是使用 oxc 的 lint 修复)
    "verbatimModuleSyntax": false,

    "experimentalDecorators": true, // 启用装饰器
    "emitDecoratorMetadata": true, // 启用装饰器元数据

    "stripInternal": true, // 隐藏 JS Doc @internal 标记的 API
    "pretty": true, // 彩色错误输出

    "strict": true,

    "noUncheckedIndexedAccess": true, // 当你通过索引签名（如 obj[key]、arr[i]）访问属性或元素时，TypeScript 会自动在返回类型中联合 undefined
    "strictNullChecks": true, // 启用严格的 null 检查
    "noFallthroughCasesInSwitch": true, // 检查 switch 语句中的 case 是否“贯穿”（即没有显式使用 break 或 return 等终止语句）。如果发现未处理的贯穿，会抛出编译错误
    "alwaysStrict": true, // 让编译出的 JavaScript 文件始终在文件顶部插入 "use strict";，即使某个 .ts 文件里没有写 use strict。
    "noImplicitThis": true, // 禁止在类型不明确的函数里使用 this，必须显式标注 this 的类型。
    "strictFunctionTypes": true, // 对函数参数做更严格的逆变（contravariant）检查，主要影响函数类型兼容性
    "strictBindCallApply": true, // 对 Function.prototype.bind、call、apply 做严格类型检查，参数个数和类型必须匹配
    "strictPropertyInitialization": true, // 类里未在构造函数中明确赋值的实例属性，必须在声明时用 !、默认值，或在构造函数里赋值，否则报错

    "exactOptionalPropertyTypes": false, //  严格区分 "可选属性不存在" 和 "属性值为 undefined" 这两种状态。不存在就是不存在不能使用 undefined 来代替。
    "noImplicitAny": false, // 禁用隐式 any 类型检查
    "noUnusedLocals": false, // 不允许有未使用的变量
    "noUnusedParameters": false, // 关闭未使用的参数错误
    "noImplicitReturns": false, // 函数不是所有代码路径都有返回值时的错误
    "noUncheckedSideEffectImports": false // false 时（默认值），允许导入可能带有副作用（Side Effects）的模块而不需要显式标记。如果设置为 true，TypeScript 会要求所有导入的模块必须显式声明是否有副作用（例如通过 "sideEffects": false 在 package.json 中标记）。

    // "types": ["bun", "assets"],
    // "typeRoots": ["./types", "./node_modules/@types"]
  },
  // "files": [] // 直接包含在编译中的文件列表, 这里包含了 bun 的类型声明和一些全局的类型声明
  "exclude": [
    // 排除产物目录
    "**/dist",
    "**/node_modules"
  ]
}

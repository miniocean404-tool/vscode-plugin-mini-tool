{
  "name": "mini-live-host",
  "version": "0.0.4",
  "description": "快速编辑 host 文件，支持多组 host 文件切换",
  "repository": {
    "type": "git",
    "url": "https://github.com/miniocean404-tool/vscode-plugin-mini-tool"
  },
  "displayName": "Mini Live Host",
  "main": "./dist/extension.js",
  "icon": "./assets/logo.png",
  "publisher": "miniocean404",
  "keywords": [
    "mini",
    "tool",
    "mini-tool",
    "minitool",
    "mini live host",
    "minilivehost",
    "live host",
    "host"
  ],
  "engines": {
    "vscode": "^1.93.0"
  },
  "categories": [
    "Other"
  ],
  "scripts": {
    "vscode:prepublish": "pnpm run build",
    "dev": "pnpm run check-types && node esbuild.ts",
    "watch:dev": "node esbuild.ts --watch",
    "build": "pnpm run check-types && node esbuild.ts --production",
    "check-types": "tsc --noEmit",
    "build:vsce": "pnpm vsce package --no-dependencies",
    "publish:vsce": "pnpm vsce publish --no-dependencies",
    "cursor:publish": "pnpm ovsx publish --no-dependencies",
    "patch-publish:vsce": "pnpm vsce publish patch --no-dependencies"
  },
  "dependencies": {
    "@vscode/test-electron": "^3.0.0",
    "dayjs": "1.11.21",
    "@vscode/sudo-prompt": "9.3.2",
    "dedent": "1.7.2"
  },
  "devDependencies": {},
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "languages": [
      {
        "id": "host",
        "aliases": [
          "host"
        ],
        "extensions": [
          ".host"
        ],
        "filenames": [
          "hosts"
        ]
      }
    ],
    "grammars": [
      {
        "language": "host",
        "scopeName": "source.host",
        "path": "./syntaxes/host.tmLanguage.json"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "mini-live-host",
          "title": "HOST 切换",
          "icon": "assets/host.png"
        }
      ]
    },
    "views": {
      "mini-live-host": [
        {
          "id": "mini-live-host",
          "name": "配置视图"
        }
      ]
    },
    "commands": [
      {
        "command": "mini-live-host.choose",
        "title": "选择"
      },
      {
        "command": "mini-live-host.unchoose",
        "title": "取消选择"
      },
      {
        "command": "mini-live-host.rename",
        "title": "重命名"
      },
      {
        "command": "mini-live-host.delete",
        "title": "删除"
      },
      {
        "command": "mini-live-host.add",
        "title": "新增",
        "icon": {
          "light": "assets/light/add.svg",
          "dark": "assets/dark/add.svg"
        }
      },
      {
        "command": "mini-live-host.edit",
        "title": "编辑"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "mini-live-host.add",
          "when": "view == 'mini-live-host'",
          "group": "navigation@1"
        },
        {
          "command": "mini-live-host.sync",
          "when": "view == 'mini-live-host'",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "mini-live-host.unchoose",
          "when": "view == 'mini-live-host' && viewItem == hostItem1",
          "group": "host@1"
        },
        {
          "command": "mini-live-host.choose",
          "when": "view == 'mini-live-host' && viewItem == hostItem0",
          "group": "host@1"
        },
        {
          "command": "mini-live-host.rename",
          "when": "view == 'mini-live-host' && viewItem =~ /hostItem/i",
          "group": "host@1"
        },
        {
          "command": "mini-live-host.delete",
          "when": "view == 'mini-live-host' && viewItem =~ /hostItem/i",
          "group": "host@1"
        }
      ]
    }
  }
}

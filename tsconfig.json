{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    // vite 会读取到这个 tsconfig 文件(位于工作空间根目录)，按照其推荐配置这两个选项
    // https://cn.vitejs.dev/guide/features.html#typescript-compiler-options
    "isolatedModules": true,

    // 这通常是 IDE 和工具链配置的用法——告诉 VSCode / tsc 整个项目的入口是 tsconfig.app.json，根 tsconfig 作为聚合器而不参与实际编译。
    // 如果引用了多个项目, 修改一个项目其他项目不会重新编译
    "composite": true
  },
  "files": [],
  // 用于将大型代码库拆分成多个子项目（子 tsconfig），并建立依赖关系，从而提升编译性能和模块化管理, 但是子模块之间不能循环引用
  "references": [
    // 聚合 ts project
    { "path": "./tsconfig.app.json" },
    { "path": "./tsconfig.node.json" }
  ]
}
